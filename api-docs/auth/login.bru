meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@trombi.fr",
    "password": "Admin123!"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3000
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("token", res.body.token);
  }
}
