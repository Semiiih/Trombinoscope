{
  "name": "trombinoscope-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev:bo": "pnpm -C back-office dev",
    "dev:be": "pnpm -C backend dev",
    "build:bo": "pnpm -C back-office build",
    "lint:bo": "pnpm -C back-office lint",
    "test:bo": "pnpm -C back-office test",
    "test:be": "pnpm -C backend test",
    "test:be:cov": "pnpm -C backend test:coverage",
    "fixtures:load": "docker exec trombi_backend node prisma/seed.js",
    "fixtures:reset": "docker exec trombi_backend npx prisma db push --force-reset --accept-data-loss && docker exec trombi_backend node prisma/seed.js",
    "studio:be": "pnpm -C backend prisma:studio",
    "db": "open http://localhost:8089"
  }
}
